{% sw_extends '@Storefront/storefront/layout/structured-data/json-ld-product.html.twig' %}

{% set hidePrice = false %}
{% if app.request.attributes.get('hidePrice') and app.request.attributes.get('hidePrice').hide %}
    {% set hidePrice = true %}
{% elseif page.extensions.hidePrice is defined and page.extensions.hidePrice.hide %}
    {% set hidePrice = true %}
{% endif %}

{% block page_product_detail_json_ld_script %}
    {% if not hidePrice %}{{ parent() }}{% endif %}
{% endblock %}
