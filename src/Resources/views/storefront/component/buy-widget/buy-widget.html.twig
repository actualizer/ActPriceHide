{% sw_extends '@Storefront/storefront/component/buy-widget/buy-widget.html.twig' %}

{% block buy_widget %}
    {% set hidePrice = false %}

    {% if app.request.attributes.get('hidePrice') and app.request.attributes.get('hidePrice').hide %}
        {% set hidePrice = true %}
    {% elseif page.extensions.hidePrice is defined and page.extensions.hidePrice.hide %}
        {% set hidePrice = true %}
    {% endif %}

    {% if hidePrice %}
        {# Drop js-magnifier-zoom-image-container: with buy_widget_buy_container empty
           the wrapper collapses to a few px and MagnifierPlugin would render its zoom
           overlay at that collapsed height. Removing the class makes the magnifier's
           document.querySelector return null, deactivating the hover lens gracefully. #}
        <div class="product-detail-buy{% if elementId %}-{{ elementId }}{% endif %}">
            {{ block('buy_widget_rich_snippets') }}
            {{ block('buy_widget_buy_container') }}
            {% if config('core.cart.wishlistEnabled') %}
                {{ block('buy_widget_wishlist') }}
            {% endif %}
            {{ block('buy_widget_ordernumber_container') }}
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block buy_widget_buy_container %}
    {% set hidePrice = false %}

    {# Check request attributes first (works for both normal and AJAX requests) #}
    {% if app.request.attributes.get('hidePrice') and app.request.attributes.get('hidePrice').hide %}
        {% set hidePrice = true %}
    {# Fallback to page extension (for normal page loads) #}
    {% elseif page.extensions.hidePrice is defined and page.extensions.hidePrice.hide %}
        {% set hidePrice = true %}
    {% endif %}

    {% if not hidePrice %}
        {{ parent() }}
    {% endif %}
{% endblock %}

